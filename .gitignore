# ── Ansible ────────────────────────────────────────────────────────────────
*.retry
.ansible/
ansible.log

# Inventory files contain real IPs, usernames, and key paths — never commit them.
# Commit only the *.example files; copy to *.ini locally before use.
inventory/*.ini

# Vault-encrypted files are fine to commit; plaintext secrets are not
*vault-password*
vault.pass
.vault_pass
secret.yml
secrets.yml
credentials.yml

# Dynamic inventory cache
inventory/.cache/
inventory/hosts.json

# ── SSH keys ───────────────────────────────────────────────────────────────
*.pem
*.key
id_rsa
id_ed25519
id_ecdsa
*.ppk

# ── Terraform ──────────────────────────────────────────────────────────────
*.tfstate
*.tfstate.backup
# tfvars contain real IPs/CIDRs/key paths — only *.tfvars.example is safe to commit
*.tfvars
!*.tfvars.example
# .terraform/ holds downloaded provider binaries — never commit
.terraform/
# .terraform.lock.hcl locks provider versions — should be committed, NOT ignored

# ── OS / editor ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# ── Kubeconfig (fetched from master by site.yml) ──────────────────────────
kubeconfig

# ── Logs & temp ───────────────────────────────────────────────────────────
*.log
/tmp/
