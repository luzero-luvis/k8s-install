# Cloud inventory (AWS / GCP / Azure / DigitalOcean / etc.)
# Replace IPs and user with your actual values.
# Set ansible_ssh_private_key_file to your cloud key pair.

[masters]
master-1 ansible_host=10.0.1.10 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/cloud_key.pem

[workers]
worker-1 ansible_host=10.0.1.11 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/cloud_key.pem
worker-2 ansible_host=10.0.1.12 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/cloud_key.pem

[k8s_cluster:children]
masters
workers

[k8s_cluster:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
cloud_provider=aws
disable_host_firewall=true
